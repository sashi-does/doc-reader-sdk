{
  "name": "doc-reader-sdk",
  "version": "1.0.0",
  "description": "Universal document text extractor SDK — PDF, DOCX, XLSX, PPTX, CSV, JSON, and more",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "doc-reader": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "read": "tsx src/cli.ts",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "pdf",
    "docx",
    "xlsx",
    "pptx",
    "csv",
    "document",
    "extractor",
    "sdk"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.15.3",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "chardet": "^2.0.0",
    "htmlparser2": "^9.1.0",
    "iconv-lite": "^0.6.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.9.0",
    "pdf-parse": "^1.1.1",
    "strip-ansi": "^7.1.0",
    "xlsx": "^0.18.5"
  }
}
